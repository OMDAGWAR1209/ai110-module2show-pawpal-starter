classDiagram
    class Task {
        +str description
        +int duration_minutes
        +Priority priority
        +bool completed
    }

    class Pet {
        +str name
        +str species
        +str preferences
        +List~Task~ tasks
        +add_task(task)
    }

    class Owner {
        +str name
        +List~Pet~ pets
        +add_pet(pet)
        +get_all_tasks()
    }

    class Planner {
        +Owner owner
        +build_plan(time_available_minutes)
        +explain_plan(plan)
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Planner "1" --> "1" Owner : manages